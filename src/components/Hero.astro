---
import { Image } from 'astro:assets';
import { formatRupiah, buildWaLink } from '../lib/format.js';

const { content, heroImage } = Astro.props;

const waMessage = `Halo, saya tertarik dengan ${content.hero_title || 'properti ini'}. Boleh info lebih lanjut?`;
const waLink = buildWaLink(content.whatsapp_number, waMessage);
---

<section class="hero">
  {heroImage && (
    <Image
      src={heroImage.image_url}
      inferSize
      alt={heroImage.caption || content.hero_title || 'Foto cluster'}
      widths={[640, 1024, 1600, 1920]}
      sizes="100vw"
      format="webp"
      quality={70}
      loading="eager"
      fetchpriority="high"
      class="hero-bg"
    />
  )}
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="container hero-content">
    {content.badge_text && <span class="hero-badge">{content.badge_text}</span>}

    <h1 class="hero-title">{content.hero_title}</h1>
    {content.hero_subtitle && <p class="hero-subtitle">{content.hero_subtitle}</p>}

    <div class="hero-price-card">
      <span class="hero-price-label">Harga mulai</span>
      <span class="hero-price">{formatRupiah(content.price_from)}</span>
      <div class="hero-promo">
        {content.promo_dp && <span class="promo-chip">{content.promo_dp}</span>}
        {content.promo_booking && <span class="promo-chip">{content.promo_booking}</span>}
      </div>
    </div>

    <div class="hero-stats">
      {content.total_unit && <div class="stat"><strong>{content.total_unit}</strong><span>Unit</span></div>}
      {content.jumlah_lantai && <div class="stat"><strong>{content.jumlah_lantai} Lantai</strong></div>}
      {content.jarak_lrt && <div class="stat"><strong>{content.jarak_lrt}</strong></div>}
      {content.jarak_tol && <div class="stat"><strong>{content.jarak_tol}</strong></div>}
    </div>

    <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-wa">
      Booking via WhatsApp
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--color-navy);
  }
  .hero-bg,
  .hero-overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    background: linear-gradient(
      to top,
      rgba(20, 33, 61, 0.92) 0%,
      rgba(20, 33, 61, 0.55) 45%,
      rgba(20, 33, 61, 0.15) 100%
    );
  }
  .hero-content {
    position: relative;
    z-index: 1;
    color: var(--color-white);
    padding-block: var(--space-xl) var(--space-lg);
  }
  .hero-badge {
    display: inline-block;
    background: var(--color-gold);
    color: var(--color-navy);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 999px;
    margin-bottom: var(--space-sm);
  }
  .hero-title {
    font-size: clamp(2.2rem, 6vw, 4rem);
    margin-bottom: var(--space-xs);
    max-width: 20ch;
  }
  .hero-subtitle {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-md);
  }
  .hero-price-card {
    background: var(--color-white);
    color: var(--color-navy);
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
    margin-bottom: var(--space-md);
  }
  .hero-price-label {
    font-size: 0.8rem;
    color: var(--color-navy-soft);
  }
  .hero-price {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-navy);
  }
  .hero-promo {
    display: flex;
    gap: 8px;
    margin-top: 4px;
    flex-wrap: wrap;
  }
  .promo-chip {
    background: var(--color-gold-soft);
    color: var(--color-navy);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 999px;
  }
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }
  .stat {
    display: flex;
    flex-direction: column;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.85);
  }
  .stat strong {
    font-size: 1.1rem;
    color: var(--color-white);
  }
  .btn-wa {
    display: inline-block;
    background: var(--color-gold);
    color: var(--color-navy);
    font-weight: 600;
    padding: 14px 32px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    box-shadow: var(--shadow-soft);
    transition: transform 0.15s ease;
  }
  .btn-wa:hover {
    transform: translateY(-2px);
  }
</style>
