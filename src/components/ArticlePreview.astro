---
import ArticleCard from './ArticleCard.astro';

const { articles } = Astro.props; // sudah { slug, title, published_at, coverSrc }
const base = import.meta.env.BASE_URL;
const latest = articles.slice(0, 3);
---

{latest.length > 0 && (
  <section id="artikel" class="article-section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Artikel</span>
        <h2>Tips & Info Seputar Hunian</h2>
      </div>

      <div class="article-scroll">
        {latest.map((a) => (
          <div class="article-scroll-item">
            <ArticleCard article={a} coverSrc={a.coverSrc} />
          </div>
        ))}
      </div>

      <div class="article-cta">
        <a href={`${base}artikel/`} class="btn-outline">Lihat Semua Artikel</a>
      </div>
    </div>
  </section>
)}

<style>
  .article-section {
    padding-block: var(--space-xl);
    background: var(--color-paper);
  }
  .section-heading {
    text-align: center;
    margin-bottom: var(--space-lg);
  }
  .eyebrow {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-gold);
    margin-bottom: 6px;
  }
  .section-heading h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }
  .article-scroll {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }
  .article-cta {
    text-align: center;
    margin-top: var(--space-lg);
  }
  .btn-outline {
    display: inline-block;
    border: 1.5px solid var(--color-navy);
    color: var(--color-navy);
    font-weight: 600;
    padding: 12px 28px;
    border-radius: var(--radius-sm);
    text-decoration: none;
  }

  /* Homepage bukan tempat baca artikel panjang - di mobile cukup scroll
     horizontal 3 kartu, biar hemat tinggi halaman & tetap kelihatan cepat. */
  @media (max-width: 720px) {
    .article-scroll {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: var(--space-sm);
      margin-inline: calc(var(--space-sm) * -1);
      padding-inline: var(--space-sm);
    }
    .article-scroll-item {
      flex: 0 0 78%;
      scroll-snap-align: start;
    }
  }
</style>
