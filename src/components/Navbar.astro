---
import { buildWaLink } from '../lib/format.js';

const { content } = Astro.props;
const waLink = buildWaLink(content.whatsapp_number, `Halo, saya tertarik dengan ${content.hero_title || 'properti ini'}.`);

const navLinks = [
  { href: '#unit', label: 'Pilihan Unit' },
  { href: '#galeri', label: 'Galeri' },
  { href: '#progress', label: 'Progress' },
  { href: '#kpr', label: 'Simulasi KPR' },
  { href: '#artikel', label: 'Artikel' }
];
---

<header class="navbar" data-navbar>
  <div class="container navbar-inner">
    <a href="#" class="brand">{content.company_name || 'Arciv Property'}</a>

    <nav class="nav-links" aria-label="Navigasi utama">
      {navLinks.map(link => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>

    <div class="navbar-actions">
      <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-wa-sm">WhatsApp</a>
      <button class="nav-toggle" data-nav-toggle aria-label="Buka menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav class="nav-mobile" data-nav-mobile aria-label="Navigasi mobile">
    {navLinks.map(link => (
      <a href={link.href}>{link.label}</a>
    ))}
    <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-wa-sm">WhatsApp</a>
  </nav>
</header>

<script>
  // Vanilla JS kecil - sengaja BUKAN Vue island, karena cuma toggle class,
  // nambah beban framework buat ini nggak worth-it demi speed.
  const toggle = document.querySelector('[data-nav-toggle]');
  const mobileNav = document.querySelector('[data-nav-mobile]');
  const navbar = document.querySelector('[data-navbar]');

  toggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(!!isOpen));
  });

  mobileNav?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => mobileNav.classList.remove('is-open'));
  });

  // Navbar berubah solid pas discroll, biar kebaca di atas hero yang transparan
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('is-scrolled', window.scrollY > 40);
  }, { passive: true });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: transparent;
    transition: background 0.2s ease, box-shadow 0.2s ease;
  }
  .navbar.is-scrolled {
    background: var(--color-white);
    box-shadow: var(--shadow-card);
  }
  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-sm);
  }
  .brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--color-white);
    text-decoration: none;
  }
  .navbar.is-scrolled .brand { color: var(--color-navy); }

  .nav-links {
    display: none;
    gap: var(--space-md);
  }
  .nav-links a {
    color: var(--color-white);
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 500;
  }
  .navbar.is-scrolled .nav-links a { color: var(--color-navy); }

  .navbar-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .btn-wa-sm {
    display: none;
    background: var(--color-gold);
    color: var(--color-navy);
    font-weight: 600;
    font-size: 0.85rem;
    padding: 8px 18px;
    border-radius: var(--radius-sm);
    text-decoration: none;
  }
  .nav-toggle {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .nav-toggle span {
    width: 22px;
    height: 2px;
    background: var(--color-white);
  }
  .navbar.is-scrolled .nav-toggle span { background: var(--color-navy); }

  .nav-mobile {
    display: none;
    flex-direction: column;
    background: var(--color-white);
    padding: var(--space-sm) var(--space-md) var(--space-md);
    box-shadow: var(--shadow-card);
  }
  .nav-mobile.is-open { display: flex; }
  .nav-mobile a {
    padding-block: 10px;
    color: var(--color-navy);
    text-decoration: none;
    border-bottom: 1px solid var(--color-paper);
  }
  .nav-mobile .btn-wa-sm {
    display: block;
    text-align: center;
    margin-top: var(--space-sm);
  }

  @media (min-width: 860px) {
    .nav-links { display: flex; }
    .btn-wa-sm { display: inline-block; }
    .nav-toggle { display: none; }
  }
</style>
