---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import UnitList from '../components/UnitList.astro';
import Gallery from '../components/Gallery.astro';
import { getSiteData, findCoverImage } from '../lib/api.js';

// Ini jalan di Node.js pas GitHub Actions build, BUKAN di browser visitor -
// jadi visitor akhir nggak pernah nunggu Apps Script sama sekali, cuma
// terima HTML+gambar yang udah jadi.
const { content, units, gallery } = await getSiteData();
const heroImage = findCoverImage(gallery, 'hero', 'hero');
---

<BaseLayout
  title={content.meta_title || content.hero_title}
  description={content.meta_description}
  ogImage={heroImage?.image_url}
>
  <Hero content={content} heroImage={heroImage} />
  <UnitList units={units} gallery={gallery} />
  <Gallery gallery={gallery} />
</BaseLayout>
