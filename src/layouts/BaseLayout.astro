---
import '@fontsource/playfair-display/500.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '../styles/tokens.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  companyName?: string;
  companyPhone?: string;
}

const {
  title,
  description = 'Cluster premium di Cibubur, dekat LRT & Tol Cibubur. Rumah baru 2 lantai mulai 900 jutaan.',
  ogImage,
  companyName = 'Arciv Property',
  companyPhone
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  name: companyName,
  url: canonicalUrl.origin + import.meta.env.BASE_URL,
  ...(companyPhone ? { telephone: companyPhone } : {})
};
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph - ini yang bikin preview WA/Instagram tampil bagus -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="generator" content={Astro.generator} />

    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>
